NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Runtime connection used by the Next.js app. Use Supabase's TRANSACTION pooler (port 6543).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# Used ONLY by drizzle-kit (db:generate, db:migrate, db:studio). Use Supabase's
# SESSION pooler (port 5432). Same URL as DATABASE_URL but with :5432 instead of :6543.
# Required because PgBouncer transaction mode (6543) silently hangs on multi-statement DDL.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-2.pooler.supabase.com:5432/postgres

CRON_SECRET=
VERCEL_API_TOKEN=

# API-SPORTS — single key powers football, basketball (NBA), American Football
# (NFL) and Formula 1 endpoints. Free plan: 100 req/day per API. Sign up at
# https://dashboard.api-sports.io (use direct path, NOT RapidAPI).
# ⚠️ Free tier is hard-locked to seasons 2022-2024 — not usable for current
# data. Dormant unless we ever upgrade to a paid plan (~$100/mo for All Sports).
API_SPORTS_KEY=

# football-data.org — Premier League, La Liga, Serie A, Bundesliga, Ligue 1,
# UCL, FIFA World Cup, Euro. Free: 10 req/min. Header: X-Auth-Token. Sign up at
# https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# BALLDONTLIE — NBA only on free tier (single-sport limit). 5 req/min.
# Header: Authorization (raw token, no "Bearer" prefix). Sign up: https://app.balldontlie.io
BALLDONTLIE_API_KEY=

# Padel API — Premier Padel + FIP tournaments, last 6 months of matches on free
# tier. 50K req/month. Header: Authorization: Bearer …. Base URL is
# https://padelapi.org/api (not the api. subdomain). https://padelapi.org
PADEL_API_KEY=
