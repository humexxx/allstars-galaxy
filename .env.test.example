# Credentials for the Playwright e2e suite. Create a dedicated Supabase user
# (email + password) for tests; never reuse a real account.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Service role key for the SAME Supabase project as your dev DB. Used by the
# e2e fixture to clean `user_sports_preferences` for the test user between
# tests via the Postgres direct URL. Treat as a secret — do not commit.
SUPABASE_SERVICE_ROLE_KEY=

# Optional overrides. Default targets the running `npm run dev` on :3010.
# E2E_PORT=3010
# E2E_BASE_URL=http://localhost:3010
